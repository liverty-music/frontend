# Copy to `.env.local` (gitignored) to run the frontend against a local backend.
# Points the Vite dev proxy for `/liverty_music` RPC calls at your local server.
# Pair with `public/config.local.json` = { "apiBaseUrl": "/" } so RPCs go
# same-origin through this proxy (no CORS, no CSP changes).
VITE_DEV_API_TARGET=http://localhost:8080
